{
  "name": "world-clock-widget",
  "version": "1.0.0",
  "description": "世界时钟桌面小工具 - 始终置顶 | 多时区 | 三种外观",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir"
  },
  "keywords": ["clock", "widget", "world-clock", "timezone"],
  "author": "QClaw",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.qclaw.world-clock",
    "productName": "WorldClockWidget",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "WorldClockWidget.exe"
    }
  }
}
